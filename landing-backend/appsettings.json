{
  "ReverseProxy": {
    "Routes": {
      "create-session": {
        "ClusterId": "chat-backend",
        "Match": {
          "Path": "/api/chats/session",
          "Methods": [ "POST" ]
        }
      },
      "get-session": {
        "ClusterId": "chat-backend",
        "Match": {
          "Path": "/api/chats/{sessionId:guid}",
          "Methods": [ "GET" ]
        }
      },
      "send-message": {
        "ClusterId": "chat-backend",
        "Match": {
          "Path": "/api/chats/{sessionId:guid}/messages",
          "Methods": [ "POST" ]
        }
      },
      "chat-hub": {
        "ClusterId": "chat-backend",
        "Match": {
          "Path": "/hubs/chat/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "chat-backend": {
        "Destinations": {
          "d1": {
            "Address": "http://localhost:5000/"
          }
        }
      }
    }
  }
}
